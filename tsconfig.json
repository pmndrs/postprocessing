{
	"include": [
		"./*.js",
		"./src",
		"./manual/assets/js/src",
		"./manual/assets/js/libs",
		"./test"
	],
	"compilerOptions": {
		// File Layout
		"rootDir": ".",
		"outDir": "./dist",
		"paths": {
			"postprocessing": ["./src/index.js"],
			"temp/*": ["./temp/*"]
		},
		// Environment Settings
		"module": "esnext",
		"target": "es2025",
		"moduleResolution": "bundler",
		"types": ["node"],
		// Style Options
		"noImplicitReturns": true,
		"noImplicitOverride": false,
		// Other
		"resolveJsonModule": true,
		"sourceMap": false,
		"skipLibCheck": true
	}
}
